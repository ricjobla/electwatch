# Local development (default): SQLite file — omit DATABASE_URL or leave unset.
# Optional path for the SQLite file (relative to backend working directory):
# SQLITE_PATH=./electwatch.db

# Docker Compose reads the following from your environment (or a `.env` file beside
# `docker-compose.yml`). Defaults match the previous baked-in credentials.
# POSTGRES_USER=electwatch
# POSTGRES_PASSWORD=electwatch
# POSTGRES_DB=electwatch

# Docker / production-style: PostgreSQL (also used when DATABASE_URL is set).
# For host-run backend against Compose Postgres, keep credentials in sync with POSTGRES_* above.
# DATABASE_URL=postgresql+psycopg2://electwatch:electwatch@localhost:5432/electwatch

# Frontend: leave unset for same-origin /api (Vite proxy locally, nginx in Docker).
# VITE_API_URL=http://localhost:8000

# Phase 3 — live scrapers (APScheduler polls every 5 minutes when enabled).
# SCRAPER_SCHEDULER_ENABLED=true
# Debug/admin routes: GET /api/admin/ingest-log, POST /api/admin/scrape/{election_id}, POST /api/admin/poll-live
# ELECTWATCH_DEBUG=true
